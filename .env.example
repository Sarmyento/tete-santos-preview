# URL canonica do site (Cloudflare Pages / dominio cliente)
PUBLIC_SITE_URL=https://exemplo.com.br

# Feed XML do CRM (prebuild: scripts/fetch-listings.mjs)
# Sem esta var, o build cai no mock public/data/listings-mock.xml
LISTINGS_FEED_URL=https://app.sarmy.com.br/api/crm/public/site/<FEED_TOKEN>/listings.xml

