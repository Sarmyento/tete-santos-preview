---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListingsCatalog from '../components/sections/ListingsCatalog.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import RevealInit from '../components/sections/RevealInit.astro';
import { site } from '../config/site';
import { getListings } from '../lib/listings';
import { breadcrumbJsonLd, itemListJsonLd } from '../lib/seo';
import { sitePath } from '../lib/paths';

const listings = getListings();
const origin = Astro.site ?? new URL(site.domain);
const pageUrl = new URL(sitePath('/imoveis'), origin).href;

const jsonLd = [
  breadcrumbJsonLd([
    { name: 'Início', url: new URL(sitePath('/'), origin).href },
    { name: 'Imóveis', url: pageUrl },
  ]),
  itemListJsonLd(
    listings.map((listing) => ({
      name: listing.title,
      url: new URL(sitePath(`/imoveis/${listing.slug}`), origin).href,
      image: listing.image.startsWith('http')
        ? listing.image
        : new URL(listing.image, origin).href,
    })),
    {
      name: 'Imóveis selecionados',
      description: `Portfólio de alto luxo em ${site.region}.`,
    },
  ),
];
---

<BaseLayout
  title={`Imóveis | ${site.name}`}
  description={`Busca avançada de imóveis de alto luxo em ${site.region}. Filtre por localização, tipo, quartos, área e preço.`}
  jsonLd={jsonLd}
>
  <section class="page-hero section reveal">
    <div class="container page-hero__inner">
      <p class="eyebrow">Portfólio</p>
      <h1>Imóveis selecionados</h1>
      <p class="page-hero__lead">
        Use a busca avançada para refinar o portfólio por bairro, tipo, quartos, área e faixa de preço.
      </p>
    </div>
  </section>

  <ListingsCatalog listings={listings} />
  <CtaBand />
  <RevealInit />
</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(var(--header-height) + var(--space-6));
  }

  .page-hero__inner {
    max-width: 760px;
  }

  .page-hero__lead {
    color: var(--color-muted);
    max-width: 52ch;
  }
</style>
