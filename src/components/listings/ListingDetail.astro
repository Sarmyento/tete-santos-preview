---
import type { Listing } from '../../lib/listings';
import { formatListingAddress, getListingMapEmbedUrl } from '../../lib/listings';
import { site } from '../../config/site';
import { assetPath } from '../../lib/paths';

interface Props {
  listing: Listing;
}

const { listing } = Astro.props;
const defaultMessage = `Olá Tetê, gostaria de receber mais informações sobre o imóvel em ${listing.neighborhood}, ${listing.city}. Código ${listing.id}. Aguardo retorno.`;
const waNumber = site.whatsapp.number;
const addressLine = formatListingAddress(listing);
const mapEmbedUrl = getListingMapEmbedUrl(listing);
const galleryImages = listing.images;
const fallbackImage = assetPath('/images/listings/fallback-property.svg');

const specs = [
  { value: String(listing.bedrooms), label: 'quartos' },
  { value: String(listing.area), label: 'm²' },
  { value: String(listing.parking), label: 'vagas' },
  { value: String(listing.suites), label: 'suítes' },
];
---

<article class="listing-detail">
  <div class="container listing-detail__shell">
    <div class="listing-detail__intro">
      <header class="listing-detail__head reveal-left">
        <span class="motion-line motion-line--wide" aria-hidden="true"></span>
        <p class="listing-detail__code">{listing.type} · Cód. {listing.id}</p>
        <h1>{listing.title}</h1>
      </header>

      <p class="listing-detail__address reveal-left">{addressLine}</p>

      <div class="listing-detail__spec-bar reveal-stagger" aria-label="Resumo do imovel">
        {
          specs.map((spec) => (
            <div class="listing-detail__spec-item">
              <span class="listing-detail__spec-value">{spec.value}</span>
              <span class="listing-detail__spec-label">{spec.label}</span>
            </div>
          ))
        }
      </div>
    </div>

    <aside class="listing-detail__sidebar reveal-right">
      <div class="listing-detail__lead-panel">
        <span class="motion-line motion-line--wide" aria-hidden="true"></span>
        <p class="listing-detail__lead-price">{listing.price}</p>
        <p class="listing-detail__lead-note">Deixe uma mensagem e retornaremos o contato</p>

        <form class="listing-detail__form" id="listing-lead-form" novalidate>
          <div class="listing-detail__field">
            <label for="lead-nome">Nome</label>
            <input id="lead-nome" type="text" name="nome" required autocomplete="name" />
          </div>
          <div class="listing-detail__field">
            <label for="lead-email">E-mail</label>
            <input id="lead-email" type="email" name="email" required autocomplete="email" />
          </div>
          <div class="listing-detail__field">
            <label for="lead-telefone">Telefone</label>
            <input id="lead-telefone" type="tel" name="telefone" autocomplete="tel" />
          </div>
          <div class="listing-detail__field">
            <label for="lead-msg">Mensagem</label>
            <textarea id="lead-msg" name="msg" rows="5" required>{defaultMessage}</textarea>
          </div>
          <button class="btn btn-accent btn-motion listing-detail__submit" type="submit">
            Enviar mensagem
          </button>
        </form>

        <p class="listing-detail__privacy">Ao informar seus dados, você concorda com a política de privacidade.</p>
      </div>
    </aside>

    <div class="listing-detail__body">
      <div class="listing-detail__gallery-shell reveal-scale" data-listing-gallery>
        <figure class="listing-detail__featured">
          <img
            src={galleryImages[0]}
            alt={listing.title}
            width="1400"
            height="788"
            loading="eager"
            fetchpriority="high"
            data-gallery-main
            onerror={`this.onerror=null;this.src='${fallbackImage}';`}
          />
          {
            galleryImages.length > 1 && (
              <>
                <button
                  type="button"
                  class="listing-detail__hero-nav listing-detail__hero-nav--prev"
                  data-gallery-main-prev
                  aria-label="Foto anterior"
                >
                  ‹
                </button>
                <button
                  type="button"
                  class="listing-detail__hero-nav listing-detail__hero-nav--next"
                  data-gallery-main-next
                  aria-label="Proxima foto"
                >
                  ›
                </button>
              </>
            )
          }
        </figure>

        {
          galleryImages.length > 0 && (
            <div class="listing-detail__gallery-strip">
              <div class="listing-detail__gallery-track-wrap">
                {
                  galleryImages.length > 1 && (
                    <button
                      type="button"
                      class="listing-detail__gallery-nav listing-detail__gallery-nav--prev"
                      data-gallery-prev
                      aria-label="Rolar miniaturas para esquerda"
                    >
                      ‹
                    </button>
                  )
                }
                <div class="listing-detail__gallery-track" data-gallery-track>
                  {
                    galleryImages.map((image, index) => (
                      <button
                        type="button"
                        class:list={['listing-detail__gallery-thumb', { 'is-active': index === 0 }]}
                        data-gallery-thumb
                        data-index={index}
                        data-src={image}
                        aria-label={`Ver foto ${index + 1} de ${galleryImages.length}`}
                        aria-current={index === 0 ? 'true' : undefined}
                      >
                        <img
                          src={image}
                          alt={`${listing.title} miniatura ${index + 1}`}
                          loading={index === 0 ? 'eager' : 'lazy'}
                          width="120"
                          height="68"
                          onerror={`this.onerror=null;this.src='${fallbackImage}';`}
                        />
                      </button>
                    ))
                  }
                </div>
                {
                  galleryImages.length > 1 && (
                    <button
                      type="button"
                      class="listing-detail__gallery-nav listing-detail__gallery-nav--next"
                      data-gallery-next
                      aria-label="Rolar miniaturas para direita"
                    >
                      ›
                    </button>
                  )
                }
              </div>
            </div>
          )
        }
      </div>

      <section class="listing-detail__block reveal-up">
        <span class="motion-line motion-line--wide" aria-hidden="true"></span>
        <h2>Descrição</h2>
        <div class="listing-detail__description">
          <p>{listing.description}</p>
        </div>
      </section>

      {
        listing.features.length > 0 && (
          <section class="listing-detail__block reveal-up">
            <span class="motion-line motion-line--wide" aria-hidden="true"></span>
            <h2>Comodidades</h2>
            <ul class="listing-detail__amenities reveal-stagger">
              {listing.features.map((feature) => <li>{feature}</li>)}
            </ul>
          </section>
        )
      }

      <section class="listing-detail__block reveal-up">
        <span class="motion-line motion-line--wide" aria-hidden="true"></span>
        <h2>Localização</h2>
        <p class="listing-detail__location-text">{addressLine}</p>
        <div class="listing-detail__map-brand-frame">
          <div class="listing-detail__map-inner">
            <iframe
              title={`Mapa: ${addressLine}`}
              src={mapEmbedUrl}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            />
          </div>
        </div>
      </section>
    </div>
  </div>
</article>

<script define:vars={{ waNumber, listingId: listing.id, listingTitle: listing.title }}>
  const form = document.getElementById('listing-lead-form');
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const nome = String(data.get('nome') ?? '').trim();
    const email = String(data.get('email') ?? '').trim();
    const telefone = String(data.get('telefone') ?? '').trim();
    const msg = String(data.get('msg') ?? '').trim();
    const text = `${msg}\n\nNome: ${nome}\nE-mail: ${email}\nTelefone: ${telefone}\nRef: ${listingId} · ${listingTitle}`;
    const url = `https://wa.me/${waNumber}?text=${encodeURIComponent(text)}`;
    window.open(url, '_blank', 'noopener,noreferrer');
  });

  const galleryRoot = document.querySelector('[data-listing-gallery]');
  if (galleryRoot) {
    const mainImg = galleryRoot.querySelector('[data-gallery-main]');
    const track = galleryRoot.querySelector('[data-gallery-track]');
    const thumbs = [...galleryRoot.querySelectorAll('[data-gallery-thumb]')];
    const prevBtn = galleryRoot.querySelector('[data-gallery-prev]');
    const nextBtn = galleryRoot.querySelector('[data-gallery-next]');
    const mainPrevBtn = galleryRoot.querySelector('[data-gallery-main-prev]');
    const mainNextBtn = galleryRoot.querySelector('[data-gallery-main-next]');
    const scrollStep = 132;
    let currentIndex = 0;

    const setActiveThumb = (index) => {
      thumbs.forEach((thumb, thumbIndex) => {
        const isActive = thumbIndex === index;
        thumb.classList.toggle('is-active', isActive);
        thumb.setAttribute('aria-current', isActive ? 'true' : 'false');
      });
    };

    const goToIndex = (index) => {
      if (!thumbs.length || !mainImg) return;
      currentIndex = (index + thumbs.length) % thumbs.length;
      const thumb = thumbs[currentIndex];
      const src = thumb.getAttribute('data-src');
      if (!src) return;
      mainImg.src = src;
      setActiveThumb(currentIndex);
      thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
    };

    thumbs.forEach((thumb, index) => {
      thumb.addEventListener('click', () => goToIndex(index));
    });

    mainPrevBtn?.addEventListener('click', () => goToIndex(currentIndex - 1));
    mainNextBtn?.addEventListener('click', () => goToIndex(currentIndex + 1));

    prevBtn?.addEventListener('click', () => {
      track?.scrollBy({ left: -scrollStep, behavior: 'smooth' });
    });

    nextBtn?.addEventListener('click', () => {
      track?.scrollBy({ left: scrollStep, behavior: 'smooth' });
    });
  }
</script>

<style>
  .listing-detail {
    --listing-media-gap: var(--space-2);
    --listing-spec-photo-gap: var(--space-3);
    padding-top: calc(var(--header-height) + var(--space-4));
    padding-bottom: var(--space-8);
  }

  .listing-detail__shell {
    display: grid;
    gap: var(--listing-media-gap);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .listing-detail__shell {
      grid-template-columns: minmax(0, 1fr) min(400px, 34%);
      grid-template-rows: auto 1fr;
      column-gap: var(--space-8);
      row-gap: var(--listing-spec-photo-gap);
    }

    .listing-detail__intro {
      grid-column: 1;
      grid-row: 1;
    }

    .listing-detail__sidebar {
      grid-column: 2;
      grid-row: 1 / span 2;
    }

    .listing-detail__body {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .listing-detail__intro {
    display: flex;
    flex-direction: column;
    gap: var(--listing-media-gap);
    min-width: 0;
  }

  .listing-detail__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    min-width: 0;
    margin-top: 0;
  }

  .listing-detail__head .motion-line,
  .listing-detail__block .motion-line,
  .listing-detail__lead-panel .motion-line {
    margin-bottom: var(--space-3);
  }

  .listing-detail__code {
    font-size: var(--text-eyebrow);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin: 0 0 var(--space-2);
  }

  .listing-detail__head h1 {
    margin-bottom: 0;
  }

  .listing-detail__address {
    margin: 0;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .listing-detail__spec-bar {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-2);
    margin-top: 0;
  }

  @media (min-width: 640px) {
    .listing-detail__spec-bar {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .listing-detail__spec-item {
    padding: var(--space-3);
    text-align: center;
    background: var(--color-white);
    border: 1px solid var(--color-line);
  }

  .listing-detail__spec-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.45rem;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .listing-detail__spec-label {
    font-size: var(--text-eyebrow);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
  }

  .listing-detail__gallery-shell {
    display: flex;
    flex-direction: column;
    gap: var(--listing-media-gap);
    margin-top: 0;
  }

  .listing-detail__featured {
    position: relative;
    margin: 0;
  }

  .listing-detail__featured img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
  }

  .listing-detail__hero-nav,
  .listing-detail__gallery-nav {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 1px solid color-mix(in srgb, var(--color-background) 35%, transparent);
    background: color-mix(in srgb, var(--color-primary) 72%, transparent);
    color: var(--color-background);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.78;
    z-index: 2;
    transition:
      opacity var(--motion-fast) var(--ease-smooth),
      background var(--motion-fast) var(--ease-smooth),
      border-color var(--motion-fast) var(--ease-smooth);
  }

  .listing-detail__hero-nav:hover,
  .listing-detail__gallery-nav:hover {
    opacity: 1;
    background: color-mix(in srgb, var(--color-primary) 88%, transparent);
    border-color: var(--color-accent);
  }

  .listing-detail__hero-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.75rem;
    height: 2.75rem;
  }

  .listing-detail__hero-nav--prev {
    left: var(--space-2);
  }

  .listing-detail__hero-nav--next {
    right: var(--space-2);
  }

  .listing-detail__gallery-strip {
    width: 100%;
  }

  .listing-detail__gallery-track-wrap {
    position: relative;
    overflow: hidden;
    min-width: 0;
  }

  .listing-detail__gallery-track {
    display: flex;
    gap: var(--space-2);
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding: 2px 0;
  }

  .listing-detail__gallery-track::-webkit-scrollbar {
    display: none;
  }

  .listing-detail__gallery-thumb {
    flex: 0 0 auto;
    width: 7.5rem;
    padding: 0;
    border: 2px solid transparent;
    background: none;
    cursor: pointer;
    transition:
      border-color var(--motion-fast) var(--ease-smooth),
      opacity var(--motion-fast) var(--ease-smooth);
    opacity: 0.72;
  }

  .listing-detail__gallery-thumb:hover,
  .listing-detail__gallery-thumb.is-active {
    opacity: 1;
    border-color: var(--color-accent);
  }

  .listing-detail__gallery-thumb img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border: 1px solid var(--color-line);
  }

  .listing-detail__gallery-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.25rem;
    height: 2.75rem;
  }

  .listing-detail__gallery-nav--prev {
    left: 0;
  }

  .listing-detail__gallery-nav--next {
    right: 0;
  }

  .listing-detail__block h2 {
    margin-bottom: var(--space-3);
  }

  .listing-detail__description p {
    margin: 0;
    line-height: 1.75;
    color: var(--color-muted);
    text-align: justify;
    text-wrap: pretty;
  }

  .listing-detail__amenities {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: justify;
  }

  .listing-detail__amenities li {
    flex: 1 1 calc(33.333% - var(--space-2));
    min-width: 9.5rem;
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--color-line);
    background: var(--color-white);
    font-size: 0.95rem;
    color: var(--color-muted);
    text-align: justify;
    text-align-last: center;
  }

  .listing-detail__location-text {
    margin: 0 0 var(--space-3);
    color: var(--color-muted);
  }

  .listing-detail__map-brand-frame {
    padding: 10px;
    background: var(--color-primary);
    border: 5px solid var(--color-accent);
    box-shadow:
      inset 0 0 0 2px var(--color-background),
      inset 0 0 0 7px var(--color-primary),
      0 8px 24px color-mix(in srgb, var(--color-primary) 22%, transparent);
  }

  .listing-detail__map-inner {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    margin: -6px;
    border: 2px solid var(--color-background);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-accent) 55%, transparent);
  }

  .listing-detail__map-inner iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    background: var(--color-white);
  }

  .listing-detail__sidebar {
    width: 100%;
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .listing-detail__sidebar {
      position: sticky;
      top: calc(var(--header-height) + var(--space-3));
      align-self: start;
    }
  }

  .listing-detail__lead-panel {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: var(--space-4);
    background: color-mix(in srgb, var(--color-primary) 84%, transparent);
    backdrop-filter: blur(18px);
    border: 1px solid color-mix(in srgb, var(--color-background) 24%, transparent);
    box-shadow: var(--shadow-card);
    color: var(--color-background);
  }

  .listing-detail__lead-price {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 2.5vw, 2.35rem);
    color: var(--color-accent);
    margin: 0 0 var(--space-1);
  }

  .listing-detail__lead-note {
    margin: 0 0 var(--space-4);
    color: color-mix(in srgb, var(--color-background) 88%, transparent);
    line-height: 1.5;
  }

  .listing-detail__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: 100%;
    margin: 0;
  }

  .listing-detail__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    width: 100%;
  }

  .listing-detail__field label {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-background) 82%, transparent);
  }

  .listing-detail__field input,
  .listing-detail__field textarea {
    display: block;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    font: inherit;
    padding: 0.75rem 0.85rem;
    border: 1px solid color-mix(in srgb, var(--color-background) 30%, transparent);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--color-background) 14%, transparent);
    color: var(--color-background);
    resize: vertical;
    min-height: 44px;
  }

  .listing-detail__field textarea {
    min-height: 128px;
    line-height: 1.5;
  }

  .listing-detail__field input:focus-visible,
  .listing-detail__field textarea:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
    border-color: var(--color-accent);
  }

  .listing-detail__submit {
    width: 100%;
    margin-top: var(--space-1);
    color: var(--color-primary-deep);
  }

  .listing-detail__privacy {
    margin: var(--space-3) 0 0;
    font-size: 0.75rem;
    line-height: 1.45;
    color: color-mix(in srgb, var(--color-background) 72%, transparent);
  }
</style>
