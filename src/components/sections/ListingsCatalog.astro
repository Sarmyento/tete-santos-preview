---
import ListingCard from '../listings/ListingCard.astro';
import type { Listing } from '../../lib/listings';
import { getListingFilterOptions } from '../../lib/listings-filters';

interface Props {
  listings: Listing[];
}

const { listings } = Astro.props;
const { cities, neighborhoods, types } = getListingFilterOptions(listings);
---

<section class="section section--tight" id="filtros" aria-labelledby="filtros-title">
  <div class="container">
    <div class="filters-panel reveal">
      <div class="filters-panel__head">
        <div>
          <p class="eyebrow">Busca avançada</p>
          <h2 id="filtros-title">Encontre o imóvel ideal</h2>
          <p class="filters-panel__lead">
            Refine por localização, tipo, quartos, área e faixa de preço. Resultados atualizados na hora.
          </p>
        </div>
        <p class="filters-panel__count" data-results-count aria-live="polite">
          {listings.length} imóveis encontrados
        </p>
      </div>

      <form class="filters-form" data-listings-filter aria-label="Filtros de busca avançada">
        <label class="filters-form__wide">
          <span>Palavra-chave</span>
          <input type="search" name="q" placeholder="Bairro, título ou referência" autocomplete="off" />
        </label>

        <label>
          <span>Cidade</span>
          <select name="city">
            <option value="">Todas</option>
            {cities.map((city) => <option value={city}>{city}</option>)}
          </select>
        </label>

        <div class="multi-select" data-multi-select="neighborhood">
          <span class="multi-select__label">Bairro</span>
          <button type="button" class="multi-select__trigger" data-multi-select-trigger>
            Todos
          </button>
          <div class="multi-select__dropdown" data-multi-select-dropdown hidden>
            {neighborhoods.map((n) => (
              <label class="multi-select__option">
                <input type="checkbox" name="neighborhood" value={n} />
                <span>{n}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="multi-select" data-multi-select="type">
          <span class="multi-select__label">Tipo</span>
          <button type="button" class="multi-select__trigger" data-multi-select-trigger>
            Todos
          </button>
          <div class="multi-select__dropdown" data-multi-select-dropdown hidden>
            {types.map((t) => (
              <label class="multi-select__option">
                <input type="checkbox" name="type" value={t} />
                <span>{t}</span>
              </label>
            ))}
          </div>
        </div>

        <label>
          <span>Quartos (mín.)</span>
          <select name="bedrooms">
            <option value="">Qualquer</option>
            <option value="1">1+</option>
            <option value="2">2+</option>
            <option value="3">3+</option>
            <option value="4">4+</option>
            <option value="5">5+</option>
          </select>
        </label>

        <label>
          <span>Preço mínimo</span>
          <input type="number" name="priceMin" min="0" step="100000" placeholder="Ex: 1000000" />
        </label>

        <label>
          <span>Preço máximo</span>
          <input type="number" name="priceMax" min="0" step="100000" placeholder="Ex: 3000000" />
        </label>

        <label>
          <span>Área mínima (m²)</span>
          <input type="number" name="areaMin" min="0" step="10" placeholder="Ex: 100" />
        </label>

        <div class="filters-form__actions">
          <button class="btn btn-primary btn-motion" type="submit">Aplicar filtros</button>
          <button class="btn btn-secondary btn-motion filters-form__reset" type="reset">Limpar</button>
        </div>
      </form>
    </div>

    <div class="listings-grid reveal-stagger" data-listings-grid>
      {
        listings.map((listing) => (
          <div
            class="listings-grid__item"
            data-listing-item
            data-title={listing.title.toLowerCase()}
            data-neighborhood={listing.neighborhood}
            data-city={listing.city}
            data-type={listing.type}
            data-bedrooms={listing.bedrooms}
            data-price={listing.priceValue}
            data-area={listing.area}
          >
            <ListingCard listing={listing} />
          </div>
        ))
      }
    </div>

    <div class="listings-pagination">
      <button class="btn btn-secondary btn-motion" data-load-more hidden aria-label="Carregar mais imóveis">
        Carregar mais 15 imóveis
      </button>
    </div>

    <p class="listings-empty" data-listings-empty hidden>
      Nenhum imóvel corresponde aos filtros selecionados. Ajuste a busca ou fale com Tetê para curadoria personalizada.
    </p>
  </div>
</section>

<script>
  const PAGE_SIZE = 15;
  const form = document.querySelector('[data-listings-filter]');
  const items = [...document.querySelectorAll('[data-listing-item]')];
  const countEl = document.querySelector('[data-results-count]');
  const emptyEl = document.querySelector('[data-listings-empty]');
  const gridEl = document.querySelector('[data-listings-grid]');
  const loadMoreBtn = document.querySelector('[data-load-more]');

  let visibleLimit = PAGE_SIZE;

  /* ---- Multi-select widget ---- */
  document.querySelectorAll('[data-multi-select]').forEach((container) => {
    const trigger = container.querySelector('[data-multi-select-trigger]');
    const dropdown = container.querySelector('[data-multi-select-dropdown]');
    const checkboxes = dropdown.querySelectorAll('input[type="checkbox"]');

    function updateTriggerText() {
      const checked = [...checkboxes].filter((cb) => cb.checked);
      trigger.textContent = checked.length
        ? `${checked.length} selecionado${checked.length === 1 ? '' : 's'}`
        : 'Todos';
    }

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !dropdown.hasAttribute('hidden');
      document.querySelectorAll('[data-multi-select-dropdown]').forEach((d) => d.setAttribute('hidden', ''));
      dropdown.toggleAttribute('hidden', isOpen);
    });

    checkboxes.forEach((cb) => {
      cb.addEventListener('change', () => {
        updateTriggerText();
        visibleLimit = PAGE_SIZE;
        applyFilters();
      });
    });

    document.addEventListener('click', (e) => {
      if (!container.contains(e.target)) {
        dropdown.setAttribute('hidden', '');
      }
    });
  });

  /* ---- Filter logic ---- */
  function applyFilters() {
    if (!form) return;

    const data = new FormData(form);
    const q = String(data.get('q') ?? '').trim().toLowerCase();
    const city = String(data.get('city') ?? '');
    const neighborhoods = data.getAll('neighborhood').filter(Boolean);
    const types = data.getAll('type').filter(Boolean);
    const bedrooms = Number(data.get('bedrooms') || 0);
    const priceMin = Number(data.get('priceMin') || 0);
    const priceMax = Number(data.get('priceMax') || 0);
    const areaMin = Number(data.get('areaMin') || 0);

    let visible = 0;

    for (const item of items) {
      const title = item.getAttribute('data-title') ?? '';
      const itemCity = item.getAttribute('data-city') ?? '';
      const itemNeighborhood = item.getAttribute('data-neighborhood') ?? '';
      const itemType = item.getAttribute('data-type') ?? '';
      const itemBedrooms = Number(item.getAttribute('data-bedrooms') ?? 0);
      const itemPrice = Number(item.getAttribute('data-price') ?? 0);
      const itemArea = Number(item.getAttribute('data-area') ?? 0);

      const matchesQuery =
        !q || title.includes(q) || itemNeighborhood.toLowerCase().includes(q) || itemCity.toLowerCase().includes(q);
      const matchesCity = !city || itemCity === city;
      const matchesNeighborhood = neighborhoods.length === 0 || neighborhoods.includes(itemNeighborhood);
      const matchesType = types.length === 0 || types.includes(itemType);
      const matchesBedrooms = !bedrooms || itemBedrooms >= bedrooms;
      const matchesPriceMin = !priceMin || itemPrice >= priceMin;
      const matchesPriceMax = !priceMax || itemPrice <= priceMax;
      const matchesArea = !areaMin || itemArea >= areaMin;

      const show =
        matchesQuery &&
        matchesCity &&
        matchesNeighborhood &&
        matchesType &&
        matchesBedrooms &&
        matchesPriceMin &&
        matchesPriceMax &&
        matchesArea;

      item.dataset.filtered = show ? 'true' : 'false';
      if (show) visible += 1;
    }

    renderVisible();
    updateCount(visible);
  }

  function renderVisible() {
    const visibleItems = items.filter((item) => item.dataset.filtered === 'true');
    let shown = 0;

    for (const item of items) {
      const filtered = item.dataset.filtered === 'true';
      if (filtered && shown < visibleLimit) {
        item.removeAttribute('hidden');
        shown += 1;
      } else {
        item.setAttribute('hidden', '');
      }
    }

    const remaining = visibleItems.length - shown;
    if (remaining > 0) {
      const nextBatch = Math.min(remaining, PAGE_SIZE);
      loadMoreBtn.textContent = `Carregar mais ${nextBatch} imóvel${nextBatch === 1 ? '' : 'es'}`;
      loadMoreBtn.removeAttribute('hidden');
    } else {
      loadMoreBtn.setAttribute('hidden', '');
    }
  }

  function updateCount(visible) {
    const shown = items.filter((item) => !item.hasAttribute('hidden')).length;
    if (countEl) {
      countEl.textContent = `${visible} imóvel${visible === 1 ? '' : 'es'} encontrado${visible === 1 ? '' : 's'}${visible !== shown ? ` (exibindo ${shown})` : ''}`;
    }
    emptyEl?.toggleAttribute('hidden', visible > 0);
    gridEl?.toggleAttribute('hidden', visible === 0);
  }

  /* ---- Event listeners ---- */
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    visibleLimit = PAGE_SIZE;
    applyFilters();
  });

  form?.addEventListener('reset', () => {
    document.querySelectorAll('[data-multi-select] input[type="checkbox"]').forEach((cb) => {
      cb.checked = false;
    });
    document.querySelectorAll('[data-multi-select-trigger]').forEach((btn) => {
      btn.textContent = 'Todos';
    });
    visibleLimit = PAGE_SIZE;
    window.setTimeout(applyFilters, 0);
  });

  form?.querySelectorAll('select, input[type="search"], input[type="number"]').forEach((field) => {
    field.addEventListener('change', () => {
      visibleLimit = PAGE_SIZE;
      applyFilters();
    });
  });

  loadMoreBtn?.addEventListener('click', () => {
    visibleLimit += PAGE_SIZE;
    renderVisible();
    const visibleItems = items.filter((item) => item.dataset.filtered === 'true');
    updateCount(visibleItems.length);
  });

  /* ---- Init ---- */
  items.forEach((item) => { item.dataset.filtered = 'true'; });
  applyFilters();

  if (window.location.hash === '#filtros') {
    document.getElementById('filtros')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
</script>

<style>
  .filters-panel {
    padding: var(--space-4);
    margin-bottom: var(--space-6);
    background: var(--color-white);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
  }

  .filters-panel__head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .filters-panel__lead {
    max-width: 58ch;
    color: var(--color-muted);
    margin-bottom: 0;
  }

  .filters-panel__count {
    align-self: end;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-primary);
    margin: 0;
  }

  .filters-form {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  @media (min-width: 900px) {
    .filters-form {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .filters-form__wide {
    grid-column: 1 / -1;
  }

  .filters-form > label {
    display: grid;
    gap: var(--space-1);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .filters-form input,
  .filters-form select {
    font: inherit;
    padding: var(--space-2);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-background);
  }

  .filters-form__actions {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .filters-form__reset {
    color: var(--color-ink);
    border-color: var(--color-line);
    background: transparent;
  }

  /* ---- Multi-select widget ---- */
  .multi-select {
    position: relative;
    display: grid;
    gap: var(--space-1);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .multi-select__label {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .multi-select__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    font: inherit;
    padding: var(--space-2);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-background);
    cursor: pointer;
    text-align: left;
    color: var(--color-muted);
  }

  .multi-select__trigger::after {
    content: '';
    display: inline-block;
    width: 0.6rem;
    height: 0.6rem;
    border: 2px solid currentColor;
    border-top: 0;
    border-left: 0;
    transform: rotate(45deg);
    margin-left: var(--space-1);
    opacity: 0.5;
    transition: transform 0.2s;
  }

  .multi-select__dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 20;
    margin-top: 2px;
    background: var(--color-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-soft);
    max-height: 240px;
    overflow-y: auto;
  }

  .multi-select__option {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2);
    cursor: pointer;
    font-weight: 400;
    font-size: 0.875rem;
    transition: background 0.15s;
  }

  .multi-select__option:hover {
    background: var(--color-background);
  }

  .multi-select__option input[type="checkbox"] {
    width: 1rem;
    height: 1rem;
    accent-color: var(--color-primary);
  }

  /* ---- Grid ---- */
  .listings-grid {
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .listings-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .listings-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .listings-empty {
    margin-top: var(--space-4);
    padding: var(--space-4);
    text-align: center;
    color: var(--color-muted);
    border: 1px dashed var(--color-line);
    background: var(--color-white);
  }

  /* ---- Pagination ---- */
  .listings-pagination {
    display: flex;
    justify-content: center;
    margin-top: var(--space-6);
  }
</style>
