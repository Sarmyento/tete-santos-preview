---
interface Props {
  title: string;
  subtitle?: string;
  /** Legado: um unico MP4 (ignora mobile/desktop se definido sozinho sem bundle) */
  videoSrc?: string;
  mobileVideoSrc?: string;
  desktopVideoSrc?: string;
  /** Poster fallback (1280) no atributo video */
  posterSrc?: string;
  posterSrc640?: string;
  posterSrc1280?: string;
  ctaLabel?: string;
  ctaHref?: string;
  /** Breakpoint alinhado ao CSS (768px) */
  desktopMinWidth?: number;
}

const {
  title,
  subtitle,
  videoSrc,
  mobileVideoSrc = '/hero-loop-mobile.mp4',
  desktopVideoSrc = '/hero-loop-desktop.mp4',
  posterSrc1280 = '/hero-poster-1280.webp',
  posterSrc640 = '/hero-poster-640.webp',
  posterSrc = posterSrc1280,
  ctaLabel = 'Fale conosco',
  ctaHref = '#contato',
  desktopMinWidth = 768,
} = Astro.props;

const useLegacySingle = Boolean(videoSrc);
const mobileSrc = useLegacySingle ? videoSrc! : mobileVideoSrc;
const desktopSrc = useLegacySingle ? videoSrc! : desktopVideoSrc;
const mediaDesktop = `(min-width: ${desktopMinWidth}px)`;
---

<section class="hero-video" data-hero-video>
  <div class="hero-video__media">
    <picture class="hero-video__poster" aria-hidden="true">
      <source srcset={posterSrc640} media="(max-width: 767px)" type="image/webp" />
      <img
        src={posterSrc1280}
        srcset={`${posterSrc640} 640w, ${posterSrc1280} 1280w`}
        sizes="100vw"
        alt=""
        width="1280"
        height="720"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <video
      class="hero-video__player"
      autoplay
      muted
      loop
      playsinline
      poster={posterSrc}
      aria-hidden="true"
      preload="metadata"
    >
      {!useLegacySingle && <source src={desktopSrc} media={mediaDesktop} type="video/mp4" />}
      <source src={mobileSrc} type="video/mp4" />
    </video>
    <div class="hero-video__overlay"></div>
  </div>
  <div class="container hero-video__copy reveal">
    <h1>{title}</h1>
    {subtitle && <p>{subtitle}</p>}
    <a class="btn btn-primary" href={ctaHref}>{ctaLabel}</a>
  </div>
</section>

<style>
  .hero-video {
    position: relative;
    min-height: min(85vh, 720px);
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .hero-video__media {
    position: absolute;
    inset: 0;
  }

  .hero-video__poster,
  .hero-video__player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-video__poster {
    z-index: 0;
  }

  .hero-video__poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-video__player {
    z-index: 1;
    object-fit: cover;
  }

  .hero-video__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(to top, rgb(0 0 0 / 0.55), rgb(0 0 0 / 0.25));
  }

  .hero-video__copy {
    position: relative;
    z-index: 3;
    color: #fff;
    max-width: 640px;
    padding-block: var(--space-8);
  }

  .hero-video__copy h1 {
    color: #fff;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video__player {
      display: none;
    }
  }

  :global(.hero-video--static) .hero-video__player {
    display: none;
  }
</style>

<script>
  document.querySelectorAll('[data-hero-video]').forEach((root) => {
    const video = root.querySelector('.hero-video__player');
    if (!(video instanceof HTMLVideoElement)) return;

    const shouldStatic = () => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const saveData = navigator.connection?.saveData;
      return reduce || Boolean(saveData);
    };

    const apply = () => {
      if (shouldStatic()) {
        video.pause();
        root.classList.add('hero-video--static');
      } else {
        root.classList.remove('hero-video--static');
        video.play().catch(() => {});
      }
    };

    apply();
    window.matchMedia('(prefers-reduced-motion: reduce)').addEventListener('change', apply);
  });
</script>
