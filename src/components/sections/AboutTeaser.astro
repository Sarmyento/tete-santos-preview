---
import { site } from '../../config/site';
import { assetPath, sitePath } from '../../lib/paths';

const p1 = {
  webp: assetPath('/images/about/tete-P1-headshot-sorriso.webp'),
  webp768: assetPath('/images/about/tete-P1-headshot-sorriso-768.webp'),
  avif: assetPath('/images/about/tete-P1-headshot-sorriso.avif'),
};
const p2 = {
  webp: assetPath('/images/about/tete-P2-headshot-3quartos.webp'),
  webp768: assetPath('/images/about/tete-P2-headshot-3quartos-768.webp'),
  avif: assetPath('/images/about/tete-P2-headshot-3quartos.avif'),
};
---

<section class="section reveal">
  <div class="container about-teaser">
    <div class="about-teaser__media">
      <picture>
        <source type="image/avif" srcset={`${p1.avif} 540w`} sizes="(min-width: 900px) 520px, 90vw" />
        <source
          type="image/webp"
          srcset={`${p1.webp768} 768w, ${p1.webp} 1080w`}
          sizes="(min-width: 900px) 520px, 90vw"
        />
        <img src={p1.webp} alt="Retrato de Tetê Santos" loading="lazy" width="540" height="540" decoding="async" />
      </picture>
      <picture class="about-teaser__secondary">
        <source type="image/avif" srcset={p2.avif} />
        <source type="image/webp" srcset={`${p2.webp768} 320w, ${p2.webp} 640w`} sizes="160px" />
        <img
          src={p2.webp}
          alt="Tetê Santos em retrato de tres quartos"
          loading="lazy"
          width="320"
          height="320"
          decoding="async"
        />
      </picture>
    </div>
    <div>
      <p class="eyebrow">Sobre</p>
      <h2>Consultoria que vende bem, não só anuncia</h2>
      <p>
        Sou corretora de imóveis de alto luxo em {site.region}. Meu trabalho combina estratégia,
        sensibilidade estética e discrição para conduzir cada negociação com segurança.
      </p>
      <p>
        Cada patrimônio recebe curadoria personalizada: posicionamento, narrativa e acompanhamento
        próximo do início ao fechamento.
      </p>
      <a class="btn btn-primary btn-motion" href={sitePath('/sobre')}>Conheça minha história</a>
    </div>
  </div>
</section>

<style>
  .about-teaser {
    display: grid;
    gap: var(--space-6);
    align-items: center;
  }

  @media (min-width: 900px) {
    .about-teaser {
      grid-template-columns: 0.95fr 1.05fr;
    }
  }

  .about-teaser__media {
    position: relative;
    max-width: 520px;
    margin-inline: auto;
  }

  .about-teaser__media > picture:first-child,
  .about-teaser__media > picture:first-child img {
    display: block;
    width: 100%;
    height: auto;
  }

  .about-teaser__media > picture:first-child img {
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-card);
  }

  .about-teaser__secondary {
    position: absolute;
    right: -12%;
    bottom: -8%;
    width: 42%;
    display: block;
  }

  .about-teaser__secondary img {
    width: 100%;
    height: auto;
    border: 4px solid var(--color-background);
    box-shadow: var(--shadow-soft);
    display: block;
  }

  @media (max-width: 899px) {
    .about-teaser__secondary {
      right: 0;
      bottom: -6%;
      width: 38%;
    }
  }
</style>
