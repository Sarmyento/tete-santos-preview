---
import { site } from '../../config/site';
import { assetPath, sitePath } from '../../lib/paths';
---

<section class="section reveal">
  <div class="container about-teaser">
    <div class="about-teaser__media">
      <img src={assetPath('/images/about/tete-P1-headshot-sorriso.png')} alt="Retrato de Tetê Santos" loading="lazy" width="540" height="540" />
      <img
        class="about-teaser__secondary"
        src={assetPath('/images/about/tete-P2-headshot-3quartos.png')}
        alt="Tetê Santos em retrato de tres quartos"
        loading="lazy"
        width="320"
        height="320"
      />
    </div>
    <div>
      <p class="eyebrow">Sobre</p>
      <h2>Consultoria que vende bem, não só anuncia</h2>
      <p>
        Sou corretora de imóveis de alto luxo em {site.region}. Meu trabalho combina estratégia,
        sensibilidade estética e discrição para conduzir cada negociação com segurança.
      </p>
      <p>
        Cada patrimônio recebe curadoria personalizada: posicionamento, narrativa e acompanhamento
        próximo do início ao fechamento.
      </p>
      <a class="btn btn-primary btn-motion" href={sitePath('/sobre')}>Conheça minha história</a>
    </div>
  </div>
</section>

<style>
  .about-teaser {
    display: grid;
    gap: var(--space-6);
    align-items: center;
  }

  @media (min-width: 900px) {
    .about-teaser {
      grid-template-columns: 0.95fr 1.05fr;
    }
  }

  .about-teaser__media {
    position: relative;
    max-width: 520px;
    margin-inline: auto;
  }

  .about-teaser__media > img:first-child {
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-card);
  }

  .about-teaser__secondary {
    position: absolute;
    right: -12%;
    bottom: -8%;
    width: 42%;
    border: 4px solid var(--color-background);
    box-shadow: var(--shadow-soft);
  }

  @media (max-width: 899px) {
    .about-teaser__secondary {
      right: 0;
      bottom: -6%;
      width: 38%;
    }
  }
</style>
