---
import { site } from '../../config/site';
import { assetPath, sitePath } from '../../lib/paths';

const p1 = {
  avif540: assetPath('/images/about/tete-P3-sobre-terraco-branco-540.avif'),
  avif320: assetPath('/images/about/tete-P3-sobre-terraco-branco-320.avif'),
  webp540: assetPath('/images/about/tete-P3-sobre-terraco-branco-540.webp'),
  webp320: assetPath('/images/about/tete-P3-sobre-terraco-branco-320.webp'),
  webp: assetPath('/images/about/tete-P3-sobre-terraco-branco.webp'),
};
const p2 = {
  avif320: assetPath('/images/about/tete-P2-headshot-3quartos-320.avif'),
  webp320: assetPath('/images/about/tete-P2-headshot-3quartos-320.webp'),
  webp540: assetPath('/images/about/tete-P2-headshot-3quartos-540.webp'),
  webp: assetPath('/images/about/tete-P2-headshot-3quartos.webp'),
};
---

<section class="section reveal">
  <div class="container about-teaser">
    <div class="about-teaser__media">
      <picture>
        <source
          type="image/avif"
          srcset={`${p1.avif320} 320w, ${p1.avif540} 540w`}
          sizes="(min-width: 900px) 480px, 85vw"
        />
        <source
          type="image/webp"
          srcset={`${p1.webp320} 320w, ${p1.webp540} 540w, ${p1.webp} 1024w`}
          sizes="(min-width: 900px) 480px, 85vw"
        />
        <img
          src={p1.webp540}
          alt="Retrato de Tetê Santos"
          loading="lazy"
          width="540"
          height="540"
          decoding="async"
        />
      </picture>
      <picture class="about-teaser__secondary">
        <source type="image/avif" srcset={`${p2.avif320} 320w`} sizes="160px" />
        <source
          type="image/webp"
          srcset={`${p2.webp320} 320w, ${p2.webp540} 540w`}
          sizes="160px"
        />
        <img
          src={p2.webp320}
          alt="Tetê Santos em retrato de tres quartos"
          loading="lazy"
          width="320"
          height="320"
          decoding="async"
        />
      </picture>
    </div>
    <div>
      <p class="eyebrow">Sobre</p>
      <h2>Consultoria que vende bem, não só anuncia</h2>
      <p>
        Sou corretora de imóveis de alto luxo em {site.region}. Meu trabalho combina estratégia,
        sensibilidade estética e discrição para conduzir cada negociação com segurança.
      </p>
      <p>
        Cada patrimônio recebe curadoria personalizada: posicionamento, narrativa e acompanhamento
        próximo do início ao fechamento.
      </p>
      <a class="btn btn-primary btn-motion" href={sitePath('/sobre')}>Conheça minha história</a>
    </div>
  </div>
</section>

<style>
  .about-teaser {
    display: grid;
    gap: var(--space-6);
    align-items: center;
  }

  @media (min-width: 900px) {
    .about-teaser {
      grid-template-columns: 0.95fr 1.05fr;
    }
  }

  .about-teaser__media {
    position: relative;
    max-width: 520px;
    margin-inline: auto;
  }

  .about-teaser__media > picture:first-child,
  .about-teaser__media > picture:first-child img {
    display: block;
    width: 100%;
    height: auto;
  }

  .about-teaser__media > picture:first-child img {
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-card);
  }

  .about-teaser__secondary {
    position: absolute;
    right: -12%;
    bottom: -8%;
    width: 42%;
    display: block;
  }

  .about-teaser__secondary img {
    width: 100%;
    height: auto;
    border: 4px solid var(--color-background);
    box-shadow: var(--shadow-soft);
    display: block;
  }

  @media (max-width: 899px) {
    .about-teaser__secondary {
      right: 0;
      bottom: -6%;
      width: 38%;
    }
  }
</style>
