---
import { assetPath, sitePath } from '../../lib/paths';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;

/** Fundo da dobra Serviços (home) — H13 living, fora da rotação hero H8/H17/H18. */
const servicesBg = assetPath('/images/sections/services-bg-living.webp');
const servicesBgAvif = assetPath('/images/sections/services-bg-living.avif');

const services = [
  {
    title: 'Compra',
    description: 'Curadoria de imóveis alinhados ao seu estilo de vida, com visitas selecionadas e análise estratégica.',
  },
  {
    title: 'Venda',
    description: 'Posicionamento premium, narrativa de valor e condução consultiva até a assinatura.',
  },
  {
    title: 'Avaliação',
    description: 'Leitura técnica e de mercado para decisões seguras sobre patrimônio de alto padrão.',
  },
  {
    title: 'Captação',
    description: 'Estratégia de entrada no mercado com discrição, requinte e foco em resultado.',
  },
];
---

<section
  class:list={['section', 'reveal', 'services-section', { 'section--dark': !compact, 'services-section--media': !compact }]}
>
  {
    !compact && (
      <div class="services-section__media" aria-hidden="true">
        <picture>
          <source type="image/avif" srcset={servicesBgAvif} />
          <img
            src={servicesBg}
            alt=""
            width="1280"
            height="720"
            loading="lazy"
            decoding="async"
          />
        </picture>
        <div class="services-section__overlay"></div>
      </div>
    )
  }
  <div class="container services-section__content">
    {
      !compact && (
        <div class="section-header">
          <p class="eyebrow">Serviços</p>
          <h2>Processo consultivo em cada etapa</h2>
          <p>Atuação completa para quem valoriza exclusividade, clareza e resultado.</p>
        </div>
      )
    }
    {
      compact && (
        <div class="section-header">
          <p class="eyebrow">Como posso ajudar</p>
          <h2>Serviços</h2>
        </div>
      )
    }
    <div class="services-grid reveal-stagger">
      {
        services.map((service) => (
          <article class="service-card">
            <span class="motion-line motion-line--wide" aria-hidden="true"></span>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </article>
        ))
      }
    </div>
    {
      !compact && (
        <div class="services-grid__footer">
          <a class="btn btn-accent btn-motion" href={sitePath('/servicos')}>
            Ver serviços completos
          </a>
        </div>
      )
    }
  </div>
</section>

<style>
  .services-section {
    position: relative;
    isolation: isolate;
  }

  .services-section--media {
    overflow: hidden;
  }

  .services-section__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .services-section__media picture,
  .services-section__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 40%;
  }

  .services-section__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-primary-deep) 78%, transparent) 0%,
        color-mix(in srgb, var(--color-primary) 88%, transparent) 45%,
        color-mix(in srgb, var(--color-primary-deep) 92%, transparent) 100%
      );
  }

  .services-section__content {
    position: relative;
    z-index: 1;
  }

  .services-grid {
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .service-card {
    padding: var(--space-4);
    border: 1px solid color-mix(in srgb, var(--color-background) 22%, transparent);
    background: color-mix(in srgb, var(--color-primary-deep) 42%, transparent);
    backdrop-filter: blur(2px);
  }

  .section:not(.section--dark) .service-card {
    border-color: var(--color-line);
    background: var(--color-white);
    backdrop-filter: none;
  }

  .service-card .motion-line {
    margin-bottom: var(--space-3);
  }

  .service-card h3 {
    font-size: 1.35rem;
    margin-bottom: var(--space-2);
  }

  .service-card p {
    color: var(--color-on-primary-muted);
    margin: 0;
  }

  .section:not(.section--dark) .service-card p {
    color: var(--color-muted);
  }

  .services-grid__footer {
    margin-top: var(--space-6);
    display: flex;
    justify-content: center;
  }
</style>
