---
import { site } from '../../config/site';
import { assetPath, sitePath } from '../../lib/paths';

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  eyebrow = site.taglineSecondary,
  title = site.tagline,
  subtitle = 'Consultoria imobiliária de alto luxo com estratégia, discrição e curadoria de patrimônio.',
  ctaLabel = 'Agende sua visita',
  ctaHref = `https://wa.me/${site.whatsapp.number}?text=${encodeURIComponent(site.whatsapp.message)}`,
} = Astro.props;

const slides = [
  {
    base: '/images/hero/tete-H2-hero-confiante',
    baseMobile: '/images/hero/tete-H5-mobile-vertical',
    alt: 'Tetê Santos em pose confiante no hero',
    altMobile: 'Tetê Santos em retrato vertical confiante',
  },
  {
    base: '/images/hero/tete-H10-hero-biblioteca-v2',
    baseMobile: '/images/hero/tete-H10-hero-biblioteca-mobile',
    alt: 'Tetê Santos na biblioteca — consultoria imobiliária',
    altMobile: 'Tetê Santos na biblioteca — versão vertical',
  },
  {
    base: '/images/hero/tete-H8-hero-consultoria-bordo',
    baseMobile: '/images/hero/tete-H11-hero-terraco-branco-mobile',
    alt: 'Tetê Santos em consultoria — living de alto padrão',
    altMobile: 'Tetê Santos no terraço — versão vertical',
  },
].map((slide) => ({
  ...slide,
  webp: assetPath(`${slide.base}.webp`),
  webp1280: assetPath(`${slide.base}-1280.webp`),
  avif: assetPath(`${slide.base}.avif`),
  avif1280: assetPath(`${slide.base}-1280.avif`),
  webpMobile: assetPath(`${slide.baseMobile}.webp`),
  webp768Mobile: assetPath(`${slide.baseMobile}-768.webp`),
  avifMobile: assetPath(`${slide.baseMobile}.avif`),
  avif768Mobile: assetPath(`${slide.baseMobile}-768.avif`),
}));

const first = slides[0];
const deferredSlides = slides.slice(1);
---

<section class="hero" data-hero-slideshow aria-label="Apresentacao principal">
  <div class="hero__slides" data-hero-slides>
    <div class="hero__slide hero__slide--1 hero__slide--active" data-hero-slide>
      <picture>
        <source
          media="(max-width: 767px)"
          type="image/avif"
          srcset={`${first.avif768Mobile} 768w, ${first.avifMobile} 1080w`}
          sizes="100vw"
        />
        <source
          media="(max-width: 767px)"
          type="image/webp"
          srcset={`${first.webp768Mobile} 768w, ${first.webpMobile} 1080w`}
          sizes="100vw"
        />
        <source
          type="image/avif"
          srcset={`${first.avif1280} 1280w, ${first.avif} 1920w`}
          sizes="100vw"
        />
        <source
          type="image/webp"
          srcset={`${first.webp1280} 1280w, ${first.webp} 1920w`}
          sizes="100vw"
        />
        <img
          src={first.webp}
          alt={first.alt}
          width="1920"
          height="1080"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </picture>
    </div>
  </div>
  <script
    type="application/json"
    data-hero-deferred
    set:html={JSON.stringify({ slides: deferredSlides })}
  />
  <div class="hero__overlay"></div>
  <div class="container hero__content">
    <p class="eyebrow hero__eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="hero__subtitle">{subtitle}</p>
    <div class="hero__actions">
      <a class="btn btn-accent btn-motion" href={ctaHref} target="_blank" rel="noopener noreferrer">
        {ctaLabel}
      </a>
      <a class="btn btn-secondary btn-motion" href={`${sitePath('/imoveis')}#filtros`}>Busca avançada com filtros</a>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector('[data-hero-slideshow]');
  const slidesRoot = root?.querySelector('[data-hero-slides]');
  const deferredNode = root?.querySelector('[data-hero-deferred]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function buildSlide(slide, index) {
    const el = document.createElement('div');
    el.className = `hero__slide hero__slide--${index + 1}`;
    el.setAttribute('data-hero-slide', '');
    const picture = document.createElement('picture');
    const sources = [
      ['(max-width: 767px)', 'image/avif', `${slide.avif768Mobile} 768w, ${slide.avifMobile} 1080w`],
      ['(max-width: 767px)', 'image/webp', `${slide.webp768Mobile} 768w, ${slide.webpMobile} 1080w`],
      [null, 'image/avif', `${slide.avif1280} 1280w, ${slide.avif} 1920w`],
      [null, 'image/webp', `${slide.webp1280} 1280w, ${slide.webp} 1920w`],
    ];
    for (const [media, type, srcset] of sources) {
      const source = document.createElement('source');
      if (media) source.media = media;
      source.type = type;
      source.srcset = srcset;
      source.sizes = '100vw';
      picture.appendChild(source);
    }
    const img = document.createElement('img');
    img.src = slide.webp;
    img.alt = slide.alt;
    img.width = 1920;
    img.height = 1080;
    img.loading = 'lazy';
    img.decoding = 'async';
    picture.appendChild(img);
    el.appendChild(picture);
    return el;
  }

  function startRotation() {
    const slideNodes = root ? [...root.querySelectorAll('[data-hero-slide]')] : [];
    if (!root || slideNodes.length < 2 || reduced) return;
    let current = 0;
    window.setInterval(() => {
      slideNodes[current]?.classList.remove('hero__slide--active');
      current = (current + 1) % slideNodes.length;
      slideNodes[current]?.classList.add('hero__slide--active');
    }, 6000);
  }

  function injectDeferred() {
    if (!slidesRoot || !deferredNode || reduced) return;
    try {
      const payload = JSON.parse(deferredNode.textContent || '{}');
      const deferred = Array.isArray(payload.slides) ? payload.slides : [];
      if (!deferred.length) return;
      deferred.forEach((slide, i) => {
        slidesRoot.appendChild(buildSlide(slide, i + 1));
      });
      deferredNode.remove();
      startRotation();
    } catch {
      // slideshow fica só no primeiro slide
    }
  }

  if (root && slidesRoot && deferredNode && !reduced) {
    const run = () => injectDeferred();
    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(run, { timeout: 2500 });
    } else {
      window.setTimeout(run, 1200);
    }
  }
</script>

<style is:global>
  .hero {
    position: relative;
    min-height: min(92vh, 920px);
    display: grid;
    align-items: end;
    overflow: hidden;
    color: var(--color-background);
    padding-top: var(--header-height);
  }

  .hero__slides {
    position: absolute;
    inset: 0;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--motion-hero-fade) var(--ease-hero);
  }

  .hero__slide--active {
    opacity: 1;
    z-index: 1;
  }

  .hero__slide picture,
  .hero__slide img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero__slide img {
    object-fit: cover;
    object-position: center 18%;
    transform: scale(1);
    transform-origin: center 20%;
    animation: heroKenBurns var(--motion-hero) var(--ease-hero) infinite alternate;
  }

  .hero__slide--1 img {
    object-position: center 12%;
    transform-origin: center 14%;
  }

  .hero__slide--2 img {
    object-position: center 15%;
    transform-origin: center 17%;
  }

  .hero__slide--3 img {
    object-position: center 18%;
    transform-origin: center 20%;
  }

  .hero__slide:not(.hero__slide--active) img {
    animation: none;
    transform: scale(1);
  }

  @keyframes heroKenBurns {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.03);
    }
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgb(62 25 35 / 0.28) 0%, rgb(62 25 35 / 0.1) 32%, rgb(62 25 35 / 0.72) 100%),
      linear-gradient(90deg, rgb(36 26 27 / 0.5) 0%, transparent 55%);
    z-index: 2;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    padding-block: var(--space-10) var(--space-12);
    max-width: 760px;
  }

  .hero__eyebrow {
    color: var(--color-accent);
  }

  .hero h1 {
    font-size: var(--text-h1);
    margin-bottom: var(--space-3);
    text-wrap: balance;
  }

  .hero__subtitle {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    max-width: 42ch;
    color: color-mix(in srgb, var(--color-background) 88%, transparent);
    margin-bottom: var(--space-4);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  @media (max-width: 767px) {
    .hero__slide img {
      object-position: center 10%;
      transform-origin: center 12%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__slide {
      transition: none;
    }

    .hero__slide:not(:first-child) {
      display: none;
    }

    .hero__slide img {
      animation: none;
    }
  }
</style>
